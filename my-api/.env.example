NODE_ENV=development
PORT=3002
APP_PORT=3002
API_PORT=3002
CORS_ALLOWED_ORIGINS=http://localhost:3002,http://127.0.0.1:3002

# Neon / Postgres (Prisma reads DATABASE_URL)
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=require

# Optional: direct connection for migrations (if your host documents it)
# DIRECT_URL=postgresql://...

# --- File storage (Vercel Blob) ---
# Create a Blob store in the Vercel dashboard and copy the "Read/Write" token.
# Required in production (e.g. Vercel serverless). In development, omit to use local ./uploads.
BLOB_READ_WRITE_TOKEN=

# Stored values:
# - With Blob: patients.profile_photo_path and clinical_documents.file_path hold full HTTPS URLs.
# - Local dev (no token): paths like /uploads/profilephotos/... (served by Express static).
